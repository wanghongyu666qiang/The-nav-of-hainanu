{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "shell",
      "label": "Build Engine",
      "command": "g++",
      "args": [
        "-g",
        "main.cpp",
        "algorithm/*.cpp",
        "algorithm/curd/*.cpp",
        "-fexec-charset=GBK",
        "-o",
        "output/main.exe"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
